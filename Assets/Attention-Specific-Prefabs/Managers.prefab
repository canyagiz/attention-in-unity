--- !u!114 &5216423691460331053
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5216423691460331042}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ab968622294b6844f8b6582192c985e7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  apiKey: 
  endpoint: https://api.openai.com/v1/chat/completions
  systemPrompt: "You will be shown a screenshot from a 3D retail scene.\r\n\r\nYour
    tasks are:\r\n1. Briefly describe the overall environment (one short paragraph).\r\n2.
    Then, carefully analyze the object that is directly centered in the screen space
    \u2014 that is, the object visually located at the middle of the image, regardless
    of camera angle or depth.\r\n\r\nFocus only on this object. Ignore nearby products
    even if they are similar or appear in the same shelf. Use any visible label,
    text, shape, packaging style, or color as clues. Do NOT guess based on shelf
    labels or adjacent items.\r\n\r\nReturn your answer in two clearly separated
    paragraphs: one for environment, one for the centered object.  \r\nLimit total
    response to 200 words\r\n"
  targetObject: {fileID: 0}
  captureSettings:
    width: 512
    height: 512
    resolution: 70
    fieldOfView: 40
    backgroundColor: {r: 0.4, g: 0.4, b: 0.4, a: 1}
